<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:id="@+id/loginActivity"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <!-- ══ CARD ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="14dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="26dp">

                <!-- Logo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_logo_box">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bolt"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Brand -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="আমার বিদ্যুৎ ~ কন্ট্রোল রুম"
                    android:textColor="#003087"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="wzpdcl · Staff Login"
                    android:textColor="#5C6E82"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="22dp" />

                <!-- Error box -->
                <LinearLayout
                    android:id="@+id/errBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_error_box"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ "
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/errMsg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ভুল Staff ID বা পাসওয়ার্ড"
                        android:textColor="#DC2626"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Staff ID field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="STAFF ID"
                    android:textColor="#5C6E82"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/idWrap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="2dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="16sp"
                        android:layout_marginEnd="9dp" />

                    <EditText
                        android:id="@+id/etStaffId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="যেমন: admin / sba1"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F1923"
                        android:textSize="14sp"
                        android:background="@null"
                        android:paddingVertical="12dp"
                        android:inputType="text"
                        android:maxLines="1" />
                </LinearLayout>

                <!-- Password field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="পাসওয়ার্ড"
                    android:textColor="#5C6E82"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/passWrap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="2dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="16sp"
                        android:layout_marginEnd="9dp" />

                    <EditText
                        android:id="@+id/etPass"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="••••••••"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F1923"
                        android:textSize="14sp"
                        android:background="@null"
                        android:paddingVertical="12dp"
                        android:inputType="textPassword"
                        android:maxLines="1" />

                    <ImageButton
                        android:id="@+id/btnEye"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@null"
                        android:src="@drawable/ic_eye"
                        app:tint="#94A3B8"
                        android:padding="4dp"
                        android:contentDescription="toggle password" />
                </LinearLayout>

                <!-- Remember / Forgot -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <CheckBox
                        android:id="@+id/cbRemember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="মনে রাখুন"
                        android:textColor="#5C6E82"
                        android:textSize="12sp"
                        android:buttonTint="#003087" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvForgot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="পাসওয়ার্ড ভুলে গেছেন?"
                        android:textColor="#1D4ED8"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- Login button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="লগইন করুন   →"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_login_btn"
                    android:elevation="0dp"
                    android:stateListAnimator="@null" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F0" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F0" />
                </LinearLayout>


            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="©developer: Md. Moshiur Rahman"
            android:textColor="#8CFFFFFF"
            android:textSize="11sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>