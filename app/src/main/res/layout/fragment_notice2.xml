<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".NoticeFragment">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >



        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            android:layout_margin="10dp"
            android:paddingTop="10dp"
            >



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="নোটিশ প্রকাশ করুন"
                    android:textSize="16sp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="5dp"
                    android:textStyle="bold"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="শিরোনাম"
                    android:textSize="12sp"
                    android:layout_margin="10dp"
                    />

                <Spinner
                    android:id="@+id/spTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="@drawable/item_bg"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginBottom="5dp"
                    />

                <EditText
                    android:id="@+id/edTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="@drawable/item_bg"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginBottom="5dp"
                    android:hint="শিরোনাম লিখুন.."
                    android:visibility="gone"
                    />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="নোটিশের ধরন"
                    android:textSize="12sp"
                    android:layout_margin="10dp"
                    />

                <Spinner
                    android:id="@+id/spNoticeType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="@drawable/item_bg"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginBottom="5dp"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="প্রভাবিত এলাকা"
                    android:textSize="12sp"
                    android:layout_margin="10dp"
                    />

                <Spinner
                    android:id="@+id/spSelectArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="@drawable/item_bg"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginBottom="5dp"
                    />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_margin="10dp"
                    android:weightSum="100"
                    >

                    <EditText
                        android:id="@+id/edDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="তারিখ দিন"
                        android:background="@drawable/item_bg"
                        android:padding="10dp"
                        android:layout_weight="60"
                        android:layout_marginRight="5dp"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_weight="40"
                        android:weightSum="20"
                        >
                        <EditText
                            android:id="@+id/edTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/item_bg"
                            android:padding="10dp"
                            android:layout_weight="10"
                            android:layout_marginLeft="5dp"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:hint="শুরুর সময়"
                            android:focusable="false"
                            android:clickable="true"
                            android:cursorVisible="false"
                            />

                        <EditText
                            android:id="@+id/edTime2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/item_bg"
                            android:padding="10dp"
                            android:layout_weight="10"
                            android:layout_marginLeft="5dp"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:hint="শেষের সময়"
                            android:focusable="false"
                            android:clickable="true"
                            android:cursorVisible="false"
                            />

                    </LinearLayout>



                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="কারণ"
                    android:layout_marginLeft="10dp"
                    />

                <EditText
                    android:id="@+id/edComplain"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:background="@drawable/item_bg"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginBottom="5dp"
                    android:textSize="14sp"
                    android:hint="আপনার সমস্যার বিবরণ দিন..."
                    android:gravity="top"
                    android:paddingLeft="10dp"
                    android:paddingTop="10dp"
                    android:layout_marginTop="5dp"
                    />


                <androidx.cardview.widget.CardView
                    android:id="@+id/complainsubmitBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_margin="10dp"
                    >

                    <TextView
                        android:id="@+id/tvNotifyBtn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="নোটিশ প্রকাশ ও সকলকে Notify করুন"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:background="#2196F3"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:clickable="true"
                        style="@style/Animation.Design.BottomSheetDialog"
                        />


                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvNotifyStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:layout_marginHorizontal="10dp"
                    android:padding="10dp"
                    android:background="@drawable/item_bg"
                    android:textColor="#4CAF50"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    />


            </LinearLayout>

        </androidx.cardview.widget.CardView>


    </LinearLayout>


</ScrollView>