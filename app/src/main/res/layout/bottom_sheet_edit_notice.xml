<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:maxHeight="560dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="নোটিশ এডিট করুন"
            android:textColor="#0F1923"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- ধরন -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ধরন"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp" />

        <Spinner
            android:id="@+id/spEditType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pick_default"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="12dp" />

        <!-- তারিখ + সময় -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="তারিখ"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="5dp" />

                <LinearLayout
                    android:id="@+id/pickEditDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pick_default"
                    android:paddingHorizontal="11dp"
                    android:paddingVertical="11dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvEditDateVal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="তারিখ"
                        android:textColor="#0F1923"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="সময়"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/etEditTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="সকাল ৮ — ৫টা"
                    android:textColorHint="#94A3B8"
                    android:textColor="#0F1923"
                    android:textSize="12sp"
                    android:background="@drawable/bg_pick_default"
                    android:paddingHorizontal="11dp"
                    android:paddingVertical="11dp"
                    android:minHeight="0dp"
                    android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- মেগাওয়াট -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="মেগাওয়াট (ঐচ্ছিক)"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp" />

        <EditText
            android:id="@+id/etEditMw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="যেমন: ২"
            android:textColorHint="#94A3B8"
            android:textColor="#0F1923"
            android:textSize="13sp"
            android:background="@drawable/bg_pick_default"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:inputType="numberDecimal"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- বার্তা -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="বার্তা"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp" />

        <EditText
            android:id="@+id/etEditMessage"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:hint="নোটিশের বিবরণ..."
            android:textColorHint="#94A3B8"
            android:textColor="#0F1923"
            android:textSize="13sp"
            android:background="@drawable/bg_pick_default"
            android:padding="12dp"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:layout_marginBottom="14dp" />

        <!-- আপডেট বাটন -->
        <Button
            android:id="@+id/btnUpdateNotice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="আপডেট করুন"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_brand"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
