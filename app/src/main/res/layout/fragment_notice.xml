<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ══ INFO BANNER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_info_amber"
            android:padding="11dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📢 নোটিশ গ্রাহকের হোম স্ক্রিনে banner হিসেবে দেখাবে + push notification যাবে।"
                android:textColor="#92400E"
                android:textSize="11sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- ══ TARGET SELECTION CARD ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- সাব-স্টেশন -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="9dp">

                    <TextView
                        android:layout_width="76dp"
                        android:layout_height="wrap_content"
                        android:text="সাব-স্টেশন"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/pickSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pick_active"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="9dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvSubVal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="গোয়ালচামট"
                            android:textColor="#0F1923"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▾"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ফিডার -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="9dp">

                    <TextView
                        android:layout_width="76dp"
                        android:layout_height="wrap_content"
                        android:text="ফিডার"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/pickFeed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pick_active"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="9dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvFeedVal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="সব ফিডার"
                            android:textColor="#0F1923"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▾"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- এলাকা -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="76dp"
                        android:layout_height="wrap_content"
                        android:text="এলাকা"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/pickArea"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pick_default"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="9dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvAreaVal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="সব এলাকা"
                            android:textColor="#5C6E82"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▾"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- HINT -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 সাব-স্টেশন → পুরো সাব-স্টেশনে | ফিডার → ফিডারের সব এলাকায় | এলাকা → শুধু সেই এলাকায়"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:background="@drawable/bg_hint_box"
                    android:padding="9dp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ NOTICE DETAILS CARD ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- ধরন -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ধরন"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="5dp" />

                <Spinner
                    android:id="@+id/spType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pick_default"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- তারিখ + সময় (2 কলাম) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="তারিখ"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="5dp" />

                        <LinearLayout
                            android:id="@+id/pickDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_pick_default"
                            android:paddingHorizontal="11dp"
                            android:paddingVertical="11dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/tvDateVal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="তারিখ বাছাই করুন"
                                android:textColor="#5C6E82"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="সময়"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="5dp" />

                        <EditText
                            android:id="@+id/etTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="সকাল ৮ — ৫টা"
                            android:textColorHint="#94A3B8"
                            android:textColor="#0F1923"
                            android:textSize="12sp"
                            android:background="@drawable/bg_pick_default"
                            android:paddingHorizontal="11dp"
                            android:paddingVertical="11dp"
                            android:minHeight="0dp"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>

                <!-- মেগাওয়াট -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="মেগাওয়াট (ঐচ্ছিক)"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/etMw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="যেমন: ২"
                    android:textColorHint="#94A3B8"
                    android:textColor="#0F1923"
                    android:textSize="13sp"
                    android:background="@drawable/bg_pick_default"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="11dp"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:layout_marginBottom="12dp" />

                <!-- বার্তা -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="বার্তা"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:hint="নোটিশের বিস্তারিত বিবরণ..."
                    android:textColorHint="#94A3B8"
                    android:textColor="#0F1923"
                    android:textSize="13sp"
                    android:background="@drawable/bg_pick_default"
                    android:padding="12dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:layout_marginBottom="12dp" />

                <!-- সাবমিট বাটন -->
                <Button
                    android:id="@+id/btnSubmitNotice"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="নোটিশ প্রকাশ ও Notify করুন"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_btn_brand"
                    android:stateListAnimator="@null" />

                <!-- টোস্ট/রেজাল্ট -->
                <TextView
                    android:id="@+id/tvNoticeToast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:padding="11dp"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ RECENT NOTICES ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="সাম্প্রতিক নোটিশ"
            android:textColor="#5C6E82"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/llNoticeList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvNoNotices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="এখনো কোনো নোটিশ পাঠানো হয়নি"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:gravity="center"
            android:padding="20dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
